---
export interface Props {
  oddsDeepDive: string;
  boxscoreSummary: string;
}

const { oddsDeepDive, boxscoreSummary } = Astro.props;
---

<div class="grid sm:grid-cols-2 gap-4">
  <div class="rounded-xl border border-border bg-bg-surface p-5">
    <h4 class="text-[11px] font-semibold uppercase tracking-wider text-text-muted mb-2 flex items-center gap-1.5">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
      </svg>
      賠率深潛
    </h4>
    <p class="text-sm text-text-secondary leading-relaxed">{oddsDeepDive}</p>
  </div>

  <div class="rounded-xl border border-border bg-bg-surface p-5">
    <h4 class="text-[11px] font-semibold uppercase tracking-wider text-text-muted mb-2 flex items-center gap-1.5">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 20V10M12 20V4M6 20v-6"/>
      </svg>
      賽事統計摘要
    </h4>
    <p class="text-sm text-text-secondary leading-relaxed">{boxscoreSummary}</p>
  </div>
</div>
